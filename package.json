{
  "name": "quarantine",
  "version": "0.1.0",
  "description": "Top-down wave-survival zombie shooter (WebGL2)",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "vite",
    "signal": "bun run scripts/ensure-signal-port.ts && cd worker && bunx wrangler dev --port 8787",
    "dev:coop": "concurrently -k -n game,signal -c green,cyan \"vite\" \"bun run signal\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "gen:sfx": "bun run scripts/gen-sfx.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json && tsc --noEmit -p sim/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "knip": "knip",
    "lint": "biome check --error-on-warnings",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "format:check": "biome format"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@elevenlabs/elevenlabs-js": "^2.54.0",
    "@types/bun": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "knip": "^6.22.0",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "lefthook"
  ]
}
